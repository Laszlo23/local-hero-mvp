NODE_ENV=development

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token

# Privy
NEXT_PUBLIC_PRIVY_APP_ID=cl_your_privy_app_id
PRIVY_APP_ID=cl_your_privy_app_id
PRIVY_APP_SECRET=your_privy_verification_key
ADMIN_USER_IDS=did:privy:admin_user_id_1,did:privy:admin_user_id_2

# Data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/localhero
REDIS_URL=redis://localhost:6379

# Object storage (S3 or Cloudflare R2)
S3_BUCKET_NAME=localhero-mvp
S3_REGION=auto
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Reward tuning
HERO_REWARD_BASE=10
